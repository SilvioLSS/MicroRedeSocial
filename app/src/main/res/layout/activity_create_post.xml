<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/background">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nova Viagem"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:textColor="@color/primary"/>

    <!-- Imagem do post -->
    <ImageView
        android:id="@+id/imgPost"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:background="@color/surface"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botão escolher imagem -->
    <Button
        android:id="@+id/btnEscolherImagem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecionar Imagem"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/imgPost"
        app:layout_constraintStart_toStartOf="parent"
        android:backgroundTint="@color/primary"
        android:textColor="@android:color/white"/>

    <!-- Campo descrição -->
    <EditText
        android:id="@+id/edtDescricao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Descreva a sua viagem"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnEscolherImagem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="@color/primary"/>

    <!-- Botão publicar -->
    <Button
        android:id="@+id/btnPublicar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Publicar viagem"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/edtDescricao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="@color/accent"
        android:textColor="@android:color/white"/>

</androidx.constraintlayout.widget.ConstraintLayout>